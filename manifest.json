{
  "manifest_version": 3,
  "name": "LocalDrop Live",
  "description": "Serve dropped local files from localhost and create an explicit temporary public link.",
  "version": "1.0.0",
  "minimum_chrome_version": "105",
  "key": "",
  "permissions": ["nativeMessaging", "storage", "clipboardWrite"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open LocalDrop Live"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
